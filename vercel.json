{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/generate-sitemap.mjs && vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.4xbo.com" }],
      "destination": "https://4xbo.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/why-us", "destination": "/index.html" },
    { "source": "/services", "destination": "/index.html" },
    { "source": "/products", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/partners/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/(logo|logo-mark|logo-og).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
